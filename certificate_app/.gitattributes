# Git attributes for proper handling across platforms

# Auto line-ending normalization
* text=auto

# Python
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf
*.wsgi text eol=lf
*.pdm text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.exe binary
*.dll binary

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Configuration
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
.editorconfig text eol=lf

# Web
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary
